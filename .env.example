# ── slink 服务端配置 ──────────────────────────
SLINK_ADDR=:18080
SLINK_BASE_URL=http://localhost:18080
SLINK_LOG_LEVEL=info
SLINK_ENV=dev

# ── PostgreSQL ────────────────────────────────
SLINK_PG_DSN=postgres://slink:slink@localhost:15432/slink?sslmode=disable
SLINK_PG_MAX_CONNS=20
SLINK_PG_MIN_CONNS=2

# ── Redis ─────────────────────────────────────
SLINK_REDIS_ADDR=localhost:16379
SLINK_REDIS_PASSWORD=
SLINK_REDIS_DB=0

# ── 短码生成（号段模式）────────────────────────
SLINK_ID_STEP_SIZE=1000
SLINK_ID_BIZ_TAG=link

# ── L1 进程内缓存（Day 8）────────────────────
# size <= 0 禁用 L1；4096 entries 大约 ~1MB 内存
SLINK_LOCAL_CACHE_SIZE=4096
SLINK_LOCAL_CACHE_TTL=1m

# ── 异步事件 buffer（Day 9 调优）────────────
# Day 8 实测 93k RPS 把 10k/1k/1s 默认值打爆（63% 丢）
# 调到 50k/2k/500ms 后 dropped 趋零
SLINK_EVENT_BUFFER_CAPACITY=50000
SLINK_EVENT_BUFFER_BATCH_SIZE=2000
SLINK_EVENT_BUFFER_FLUSH_INTERVAL=500ms
