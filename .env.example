# ── slink 服务端配置 ──────────────────────────
SLINK_ADDR=:18080
SLINK_BASE_URL=http://localhost:18080
SLINK_LOG_LEVEL=info
SLINK_ENV=dev

# ── PostgreSQL ────────────────────────────────
SLINK_PG_DSN=postgres://slink:slink@localhost:15432/slink?sslmode=disable
SLINK_PG_MAX_CONNS=20
SLINK_PG_MIN_CONNS=2

# ── Redis ─────────────────────────────────────
SLINK_REDIS_ADDR=localhost:16379
SLINK_REDIS_PASSWORD=
SLINK_REDIS_DB=0

# ── 短码生成（号段模式）────────────────────────
SLINK_ID_STEP_SIZE=1000
SLINK_ID_BIZ_TAG=link

# ── 缓存策略 ─────────────────────────────────
SLINK_CACHE_TTL=24h
SLINK_CACHE_TTL_JITTER=10m
SLINK_CACHE_NULL_TTL=1m

# ── 限流 ────────────────────────────────────
SLINK_RATE_LIMIT_PER_IP=100
SLINK_RATE_LIMIT_BURST=200
